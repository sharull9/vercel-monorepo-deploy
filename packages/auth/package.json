{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsc --watch",
    "auth:generate": "pnpm dlx auth@latest generate --config src/index.ts --output ../db/src/schema/auth.ts",
    "auth:migrate": "pnpm dlx auth@latest migrate --config src/index.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "catalog:",
    "@workspace/db": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
