{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsc --watch",
    "auth:generate": "pnpm dlx auth@latest generate --config src/index.ts --output ../db/src/schema/auth.ts",
    "auth:migrate": "pnpm dlx auth@latest migrate --config src/index.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@workspace/db": "workspace:*",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "1.0.0-rc.4",
    "tsdown": "^0.22.3",
    "tsx": "^4.23.0",
    "typescript": "catalog:"
  }
}
