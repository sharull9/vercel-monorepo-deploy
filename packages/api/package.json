    "@workspace/db": "workspace:*",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3"
